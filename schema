create table public.sites (
  id bigint generated always as identity not null,
  district_id integer not null,
  name text not null,
  lat double precision not null,
  lng double precision not null,
  level text not null,
  suitability_score numeric(6, 2) not null default 0,
  reason text not null,
  created_at timestamp with time zone not null default now(),
  constraint sites_pkey primary key (id),
  constraint sites_level_check check (
    (
      level = any (
        array[
          'primary'::text,
          'secondary'::text,
          'tertiary'::text
        ]
      )
    )
  )
) TABLESPACE pg_default;

create index IF not exists idx_sites_district_level on public.sites using btree (district_id, level) TABLESPACE pg_default;

create index IF not exists idx_sites_score on public.sites using btree (suitability_score desc) TABLESPACE pg_default;
